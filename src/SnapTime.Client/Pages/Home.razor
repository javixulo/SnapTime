    .snaptime-center-panel {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
    }
    .snaptime-right-panel {
        width: 15%;
        min-width: 140px;
        border-left: 1px solid #e0e0e0;
        padding: 16px;
        background: #fafafa;
    }
    .snaptime-placeholder {
        color: #999;
        font-style: italic;
        padding: 24px;
        text-align: center;
