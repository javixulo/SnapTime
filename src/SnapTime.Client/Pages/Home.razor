@page "/"
@using SnapTime.Client.Models

<PageTitle>SnapTime</PageTitle>

<div class="snaptime-page">
    <div class="snaptime-top-bar">
        <ScanPanel SelectedFolderPath="@_selectedPath" />
    </div>

    <div class="snaptime-layout">
        <aside class="snaptime-left-panel">
            <FolderTreePanel OnFolderSelected="@((path) => _selectedPath = path)" />
        </aside>

        <section class="snaptime-center-panel">
            <PhotoGrid SelectedFolderPath="@_selectedPath"
                       OnPhotoSelected="@HandlePhotoSelected"
                       OnNavigate="@HandleGridNavigate" />
        </section>

        <aside class="snaptime-right-panel">
            <div class="snaptime-right-panel-top">
                <PhotoDetail SelectedAssetId="@_selectedPhotoId"
                             SelectedAssetPath="@_selectedPhotoPath"
                             OnAccept="@HandleAcceptSuggestion"
                             OnReject="@HandleRejectSuggestion" />
            </div>
            <div class="snaptime-right-panel-bottom">
                <div class="snaptime-placeholder">Chat (F9)</div>
            </div>
        </aside>
    </div>
</div>

@code {
    private string? _selectedPath;
    private Guid? _selectedPhotoId;
    private string? _selectedPhotoPath;

    private void HandlePhotoSelected(PhotoGridItem item)
    {
        _selectedPhotoPath = item.Path;
        _selectedPhotoId = item.Id != Guid.Empty ? item.Id : null;
    }

    private void HandleAcceptSuggestion()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }

    private void HandleRejectSuggestion()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }

    private void HandleGridNavigate()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }
}

<style>
    .snaptime-page {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }
    .snaptime-top-bar {
        padding: 8px 16px;
        border-bottom: 1px solid #e0e0e0;
        background: #f5f5f5;
        flex-shrink: 0;
    }
    .snaptime-layout {
        display: flex;
        flex: 1;
        min-height: 0;
        gap: 0;
    }
    .snaptime-left-panel {
        width: 20%;
        min-width: 200px;
        border-right: 1px solid #e0e0e0;
        overflow-y: auto;
        background: #fafafa;
    }
    .snaptime-center-panel {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
    }
    .snaptime-right-panel {
        width: 20%;
        min-width: 140px;
        border-left: 1px solid #e0e0e0;
        background: #fafafa;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .snaptime-right-panel-top {
        flex: 1;
        overflow-y: auto;
    }
    .snaptime-right-panel-bottom {
        border-top: 1px solid #e0e0e0;
        padding: 16px;
        flex-shrink: 0;
    }
    .snaptime-placeholder {
        color: #999;
        font-style: italic;
        padding: 24px;
        text-align: center;
    }
</style>
