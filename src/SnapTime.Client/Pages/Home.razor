@page "/"
@using SnapTime.Client.Models
@using SnapTime.Client.Services
@implements IDisposable
@inject IScanStateService ScanStateService
@inject IPhotoClient PhotoClient

<PageTitle>SnapTime</PageTitle>

<div class="snaptime-page">
    <div class="snaptime-top-bar">
        <div class="snaptime-top-bar-left">
            <ScanPanel SelectedFolderPath="@_selectedPath" />
        </div>
        <div class="snaptime-top-bar-right">
            <BatchActions HasRecommendations="@_hasRecommendations"
                          RecommendationCount="@_recommendationCount"
                          CurrentFolderPath="@_selectedPath" />
        </div>
    </div>

    <div class="snaptime-layout">
        <aside class="snaptime-left-panel">
            <FolderTreePanel OnFolderSelected="@(async (path) => { _selectedPath = path; await UpdateRecommendationCountAsync(); StateHasChanged(); })" />
        </aside>

        <section class="snaptime-center-panel">
            <PhotoGrid SelectedFolderPath="@_selectedPath"
                       RefreshTrigger="@_gridRefreshCounter"
                       OnPhotoSelected="@HandlePhotoSelected"
                       OnNavigate="@HandleGridNavigate" />
        </section>

        <aside class="snaptime-right-panel">
            <div class="snaptime-right-panel-top">
                <PhotoDetail SelectedAssetId="@_selectedPhotoId"
                             SelectedAssetPath="@_selectedPhotoPath"
                             OnAccept="@HandleAcceptSuggestion"
                             OnReject="@HandleRejectSuggestion" />
            </div>
            <div class="snaptime-right-panel-bottom">
                <div class="snaptime-placeholder">Chat (F9)</div>
            </div>
        </aside>
    </div>
</div>

@code {
    private string? _selectedPath;
    private Guid? _selectedPhotoId;
    private string? _selectedPhotoPath;
    private bool _hasRecommendations;
    private int _recommendationCount;
    private int _gridRefreshCounter;

    protected override void OnInitialized()
    {
        ScanStateService.StateChanged += OnScanStateChanged;
    }

    public void Dispose()
    {
        ScanStateService.StateChanged -= OnScanStateChanged;
    }

    private async void OnScanStateChanged()
    {
        if (ScanStateService is { HasCompletedScan: true, IsScanning: false })
        {
            // Increment to force PhotoGrid to reload with fresh data from the DB
            _gridRefreshCounter++;
            await UpdateRecommendationCountAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdateRecommendationCountAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(_selectedPath))
            {
                _hasRecommendations = false;
                _recommendationCount = 0;
                return;
            }

            var response = await PhotoClient.GetPhotosAsync(_selectedPath, 1, int.MaxValue);
            _recommendationCount = response.Items.Count(i => i.HasSuggestion);
            _hasRecommendations = _recommendationCount > 0;
        }
        catch
        {
            _hasRecommendations = false;
            _recommendationCount = 0;
        }
    }

    private void HandlePhotoSelected(PhotoGridItem item)
    {
        _selectedPhotoPath = item.Path;
        _selectedPhotoId = item.Id != Guid.Empty ? item.Id : null;
    }

    private void HandleAcceptSuggestion()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }

    private void HandleRejectSuggestion()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }

    private void HandleGridNavigate()
    {
        _selectedPhotoId = null;
        _selectedPhotoPath = null;
    }
}

<style>
    .snaptime-page {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }
    .snaptime-top-bar {
        padding: 8px 16px;
        border-bottom: 1px solid #e0e0e0;
        background: #f5f5f5;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
    .snaptime-top-bar-left {
        display: flex;
        align-items: center;
    }
    .snaptime-top-bar-right {
        display: flex;
        align-items: center;
    }
    .snaptime-layout {
        display: flex;
        flex: 1;
        min-height: 0;
        gap: 0;
    }
    .snaptime-left-panel {
        width: 20%;
        min-width: 200px;
        border-right: 1px solid #e0e0e0;
        overflow-y: auto;
        background: #fafafa;
    }
    .snaptime-center-panel {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
    }
    .snaptime-right-panel {
        width: 20%;
        min-width: 140px;
        border-left: 1px solid #e0e0e0;
        background: #fafafa;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .snaptime-right-panel-top {
        flex: 1;
        overflow-y: auto;
    }
    .snaptime-right-panel-bottom {
        border-top: 1px solid #e0e0e0;
        padding: 16px;
        flex-shrink: 0;
    }
    .snaptime-placeholder {
        color: #999;
        font-style: italic;
        padding: 24px;
        text-align: center;
    }
</style>
