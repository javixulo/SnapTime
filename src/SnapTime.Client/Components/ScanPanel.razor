@* [F4-US-000 / F7-US-001] ScanPanel — Escaneo con progreso, cancelación y reescaneo *@
@using SnapTime.Client.Services

<div class="scan-panel">
    <div class="scan-controls">
        <label class="scan-checkbox-label">
            <input type="checkbox" @bind="_includeSubfolders" />
            Incluir subcarpetas
        </label>
        <button @onclick="StartScanAsync" disabled="@_isScanning">
            Escanear
        </button>

        @if (_isScanning)
        {
            <button @onclick="CancelScanAsync">Cancelar</button>
            <span class="scan-progress">Procesando @_processed de @_total archivos</span>
        }
    </div>

    @if (_state == "Cancelled")
    {
        <span class="scan-status cancelled">Cancelled</span>
    }

    @if (_state == "Completed")
    {
        <span class="scan-status completed">Completed</span>
    }

    @if (_currentJob is not null)
    {
        <div class="scan-job-detail">
            <span>Job: @_currentJob.Id</span>
            <span>Ruta: @_currentJob.RootPath</span>
            <span>Progreso: @_currentJob.ProcessedFiles / @_currentJob.TotalFiles</span>
        </div>
    }

    @if (_error is not null)
    {
        <div class="scan-error">@_error</div>
    }
</div>

<style>
    .scan-panel {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .scan-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .scan-checkbox-label {
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-size: 13px;
        user-select: none;
    }
    .scan-checkbox-label input[type="checkbox"] {
        cursor: pointer;
    }
    .scan-progress {
        font-size: 12px;
        color: #555;
    }
    .scan-status {
        font-size: 12px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
    }
    .scan-status.cancelled {
        color: #d32f2f;
        background: #ffebee;
    }
    .scan-status.completed {
        color: #2e7d32;
        background: #e8f5e9;
    }
    .scan-job-detail {
        display: flex;
        gap: 12px;
        font-size: 11px;
        color: #999;
    }
    .scan-error {
        font-size: 12px;
        color: #d32f2f;
    }
</style>
