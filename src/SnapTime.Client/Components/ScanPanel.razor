@* [F4-US-000] ScanPanel — Input de ruta, botón "Escanear", indicador de progreso *@
@using SnapTime.Client.Services

<div class="scan-panel">
    <div class="scan-controls">
        <label class="scan-checkbox-label">
            <input type="checkbox" @bind="_includeSubfolders" />
            Incluir subcarpetas
        </label>
        <button @onclick="StartScanAsync" disabled="@_isScanning">
            Escanear
        </button>
    </div>

    @if (_currentJob is not null)
    {
        <div class="scan-progress">
            <span><strong>Job:</strong> @_currentJob.Id</span>
            <span><strong>Ruta:</strong> @_currentJob.RootPath</span>
            <span><strong>Estado:</strong> @_currentJob.Status</span>
            <span><strong>Progreso:</strong> @_currentJob.ProcessedFiles / @_currentJob.TotalFiles</span>
        </div>
    }

    @if (_error is not null)
    {
        <div class="scan-error" style="color: red;">
            @_error
        </div>
    }
</div>

<style>
    .scan-panel {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .scan-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .scan-checkbox-label {
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-size: 13px;
        user-select: none;
    }
    .scan-checkbox-label input[type="checkbox"] {
        cursor: pointer;
    }
    .scan-progress {
        display: flex;
        gap: 16px;
        font-size: 12px;
        color: #555;
    }
    .scan-error {
        font-size: 12px;
    }
</style>
