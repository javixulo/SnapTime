@* [F7-US-004] BatchActions — Botones de lote para aprobar/rechazar sugerencias *@
@using SnapTime.Client.Services

<div class="batch-actions">
    <button class="@AcceptAllClass" @onclick="OpenModalAcceptFolder" disabled="@IsDisabled">
        Aceptar Todo
    </button>
    <button class="@RejectAllClass" @onclick="OpenModalRejectFolder" disabled="@IsDisabled">
        Rechazar Todo
    </button>
    <button class="@AcceptTotalClass" @onclick="OpenModalAcceptTotal" disabled="@IsDisabled">
        Aceptar Total
    </button>
    <button class="@RejectTotalClass" @onclick="OpenModalRejectTotal" disabled="@IsDisabled">
        Rechazar Total
    </button>

    @if (_errorMessage is not null)
    {
        <div class="batch-error">@_errorMessage</div>
    }
    @if (_showConfirmModal)
    {
        <div class="confirm-modal">
            <div class="confirm-backdrop" @onclick="CancelModal"></div>
            <div class="confirm-dialog">
                <p>@GetConfirmText()</p>
                <div class="batch-confirm-actions">
                    <button class="btn-confirm" @onclick="ConfirmAsync">Confirmar</button>
                    <button class="btn-cancel" @onclick="CancelModal">Cancelar</button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .batch-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .batch-actions button {
        padding: 6px 14px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        color: #333;
        transition: background 0.15s, color 0.15s;
    }
    .batch-actions button:hover:not(.disabled) {
        background: #f0f0f0;
    }
    .batch-actions button.disabled {
        background: #e0e0e0;
        color: #999;
        cursor: not-allowed;
        pointer-events: none;
        border-color: #ddd;
    }
    .btn-accept-all,
    .btn-accept-total {
        border-color: #4caf50;
        color: #2e7d32;
    }
    .btn-accept-all:hover:not(.disabled),
    .btn-accept-total:hover:not(.disabled) {
        background: #e8f5e9;
    }
    .btn-reject-all,
    .btn-reject-total {
        border-color: #f44336;
        color: #c62828;
    }
    .btn-reject-all:hover:not(.disabled),
    .btn-reject-total:hover:not(.disabled) {
        background: #ffebee;
    }
    .confirm-modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .confirm-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.3);
    }
    .confirm-dialog {
        position: relative;
        background: #fff;
        border-radius: 8px;
        padding: 24px;
        min-width: 300px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
        z-index: 1001;
    }
    .confirm-dialog p {
        margin: 0 0 16px 0;
        font-size: 14px;
        color: #333;
    }
    .batch-confirm-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }
    .btn-confirm {
        padding: 8px 20px;
        border: none;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        background: #1976d2;
        color: #fff;
    }
    .btn-confirm:hover {
        background: #1565c0;
    }
    .btn-cancel {
        padding: 8px 20px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        color: #555;
    }
    .btn-cancel:hover {
        background: #f5f5f5;
    }
    .batch-error {
        color: #d32f2f;
        background: #ffebee;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 12px;
        margin-bottom: 8px;
    }
</style>
