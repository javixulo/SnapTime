@* [F6][F7] PhotoDetail — Panel de detalle de foto con metadatos, confianza, evidencia y botones Aceptar/Rechazar *@
@using SnapTime.Client.Models
@using SnapTime.Client.Services
@implements IDisposable

@if (!SelectedAssetId.HasValue && string.IsNullOrEmpty(SelectedAssetPath))
{
    <div class="photo-detail-container">
        <div class="photo-detail-empty">Selecciona una foto</div>
    </div>
}
else if (_isLoading)
{
    <div class="photo-detail-container">
        <div class="photo-detail-loading">Cargando...</div>
    </div>
}
else if (_error is not null)
{
    <div class="photo-detail-container">
        <div class="photo-detail-error">@_error</div>
    </div>
}
else if (_detail is not null)
{
    <div class="photo-detail-container">
        <h3 class="photo-detail-name">@_detail.FileName</h3>
        <div class="photo-detail-path">@_detail.FilePath</div>
        <div class="photo-detail-size">@FormatFileSize(_detail.FileSize)</div>

        <div class="photo-detail-metadata">
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Original:</span>
                <span>@_detail.DateTimeOriginal?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">SubSec:</span>
                <span>@_detail.SubSecDateTimeOriginal</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Creado:</span>
                <span>@_detail.CreateDate?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Modificado:</span>
                <span>@_detail.ModifyDate?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Fichero creado:</span>
                <span>@_detail.FileCreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Fichero mod:</span>
                <span>@_detail.FileModifiedAt?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            @if (_detail.SuggestedDate is not null)
            {
                <div class="photo-detail-metadata-row">
                    <span class="photo-detail-metadata-label">Sugerida:</span>
                    <span>@_detail.SuggestedDate?.ToString("dd/MM/yyyy")</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(_detail.SuggestedByHeuristic))
            {
                <div class="photo-detail-metadata-row">
                    <span class="photo-detail-metadata-label">Heurística:</span>
                    <span>@_detail.SuggestedByHeuristic</span>
                </div>
            }
        </div>

        @if (_detail.SuggestedDate is not null)
        {
            <div class="suggestion-status @GetReviewStatusClass()">
                @GetReviewStatusLabel()
            </div>
        }

        <div class="photo-detail-confidence-section">
            <div class="photo-detail-confidence-label">Confianza: @_detail.ConfidenceScore%</div>
            <div class="photo-detail-confidence-bar @GetConfidenceClass()" style="width: @_detail.ConfidenceScore%">
                @_detail.ConfidenceScore
            </div>
        </div>

        @if (_detail.Evidence is { Count: > 0 })
        {
            <div class="photo-detail-evidence-section">
                <h4>Evidencia</h4>
                <div class="photo-detail-evidence-list">
                    @foreach (var ev in _detail.Evidence)
                    {
                        <div class="photo-detail-evidence-item">
                            <div class="evidence-header">
                                <span class="evidence-name">@ev.HeuristicName</span>
                                <span class="evidence-weight">@ev.Weight.ToString("F2")</span>
                                <span class="evidence-direction @GetDirectionClass(ev.Direction)">@ev.Direction</span>
                            </div>
                            <div class="evidence-description">@((MarkupString)ev.Description)</div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="photo-detail-actions">
            <button class="@GetAcceptClass()" @onclick="HandleAcceptAsync" disabled="@(!_canAccept)">Aceptar</button>
            <button class="@GetRejectClass()" @onclick="HandleRejectAsync" disabled="@(!_canAccept)">Rechazar</button>
        </div>
    </div>
}
else if (_fileMetadata is not null)
{
    <div class="photo-detail-container">
        <h3 class="photo-detail-name">@_fileMetadata.FileName</h3>
        <div class="photo-detail-path">@_fileMetadata.FilePath</div>
        <div class="photo-detail-size">@FormatFileSize(_fileMetadata.FileSize)</div>

        <div class="photo-detail-metadata">
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Original:</span>
                <span>@_fileMetadata.DateTimeOriginal?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">SubSec:</span>
                <span>@_fileMetadata.SubSecDateTimeOriginal</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Creado:</span>
                <span>@_fileMetadata.CreateDate?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Modificado:</span>
                <span>@_fileMetadata.ModifyDate?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Fichero creado:</span>
                <span>@_fileMetadata.FileCreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="photo-detail-metadata-row">
                <span class="photo-detail-metadata-label">Fichero mod:</span>
                <span>@_fileMetadata.FileModifiedAt?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
    </div>
}


